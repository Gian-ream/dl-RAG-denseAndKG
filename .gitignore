# Secrets
.hf_token

# Data files (too large for git). Directories are kept (via .gitkeep) so the
# expected layout is visible; the only tracked files are the minimal inputs
# needed to run notebook 09 standalone (gold answers + Llama-2 responses).
data/**
!data/**/
!data/**/.gitkeep
!data/NQ_answer/queries_curated.jsonl
!data/NQ_answer/llm_eval/llm_responses_*.jsonl

# Python
.venv/
__pycache__/
*.pyc

# IDE
.idea/

# Jupyter
.ipynb_checkpoints/

# Claude Code local settings (per-machine, not shared)
.claude/settings.local.json

# Local scratch / temporary work
.tmp/
# Local archive staged for Drive upload
data.zip
